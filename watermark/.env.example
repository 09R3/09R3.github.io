# PostgreSQL connection
# IMPORTANT — Docker networking note:
#   If Postgres runs on the SAME machine as this container, do NOT use "localhost".
#   Use your server's LAN IP (e.g. 192.168.1.100) or 172.17.0.1 (Docker bridge default).
#   If Postgres is on a DIFFERENT machine, use that machine's IP address.
DB_HOST=192.168.1.100
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_username
DB_PASSWORD=your_password

# App port inside the container — leave as 4000 (the deploy script maps it to 3067 externally)
PORT=4000
