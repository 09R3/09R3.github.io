    { "id": "pp3a", "name": "CVC PP 3A", "influxSite": "CVC_PP3A", "pumps": ["A","B","C","D","E","F","G","H","J"] },
    { "id": "pp3b", "name": "CVC PP 3B", "influxSite": "CVC_PP3B", "pumps": ["A","B","C"], "pumpLabels": {"A":"K","B":"L","C":"M"} },
    { "id": "pp4a", "name": "CVC PP 4A", "influxSite": "CVC_PP4A", "pumps": ["A","B","C","D","E","F","G","H","J"] },
    { "id": "pp4b", "name": "CVC PP 4B", "influxSite": "CVC_PP4B", "pumps": ["A","B","C"], "pumpLabels": {"A":"K","B":"L","C":"M"} },
