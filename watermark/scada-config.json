{
  "pollMs": 5000,
  "defaultSensors": ["FBLvl", "ABLvl", "DSLvl", "TRLvl", "AirPSI", "InTmp"],
  "sensorMeta": {
    "FBLvl":  { "label": "Forebay Level",   "unit": "ft",  "kind": "level" },
    "ABLvl":  { "label": "Afterbay Level",  "unit": "ft",  "kind": "level" },
    "DSLvl":  { "label": "Downstream Level", "unit": "ft", "kind": "level" },
    "TRLvl":  { "label": "Trash Rack Lvl",  "unit": "ft",  "kind": "level" },
    "AirPSI": { "label": "Air Pressure",    "unit": "psi", "kind": "pressure" },
    "InTmp":  { "label": "Bldg Temp",       "unit": "°F", "kind": "temp" },
    "AQFlw":  { "label": "DWR 1",           "unit": "cfs", "kind": "flow" },
    "AQFlw2": { "label": "DWR 2",           "unit": "cfs", "kind": "flow" }
  },
  "sites": [
    { "id": "pp1a", "name": "CVC PP 1A", "influxSite": "CVC_PP1A", "pumps": ["A","B","C","D","E","F","G","H"], "sensors": ["FBLvl","ABLvl","DSLvl","TRLvl","AirPSI","InTmp","AQFlw","AQFlw2"], "computedSensors": [{"label":"DWR Total","unit":"cfs","sum":["AQFlw","AQFlw2"]}] },
    { "id": "pp1b", "name": "CVC PP 1B", "influxSite": "CVC_PP1B", "pumps": ["A","B","C"], "pumpLabels": {"A":"K","B":"L","C":"M"} },
    { "id": "pp2a", "name": "CVC PP 2A", "influxSite": "CVC_PP2A", "pumps": ["A","B","C","D","E","F","G","H"] },
    { "id": "pp2b", "name": "CVC PP 2B", "influxSite": "CVC_PP2B", "pumps": ["A","B","C"], "pumpLabels": {"A":"K","B":"L","C":"M"} },
    { "id": "pp3a", "name": "CVC PP 3A", "influxSite": "CVC_PP3A", "pumps": ["A","B","C","D","E","F","G","H","J"] },
    { "id": "pp3b", "name": "CVC PP 3B", "influxSite": "CVC_PP3B", "pumps": ["A","B","C"], "pumpLabels": {"A":"K","B":"L","C":"M"} },
    { "id": "pp4a", "name": "CVC PP 4A", "influxSite": "CVC_PP4A", "pumps": ["A","B","C","D","E","F","G","H","J"] },
    { "id": "pp4b", "name": "CVC PP 4B", "influxSite": "CVC_PP4B", "pumps": ["A","B","C"], "pumpLabels": {"A":"K","B":"L","C":"M"} },
    { "id": "pp5a", "name": "CVC PP 5A", "influxSite": "CVC_PP5A", "pumps": ["A","B","C","D","E","F","G","H","J"] },
    { "id": "pp5b", "name": "CVC PP 5B", "influxSite": "CVC_PP5B", "pumps": ["A","B","C"], "pumpLabels": {"A":"K","B":"L","C":"M"} },
    { "id": "pp6a", "name": "CVC PP 6A", "influxSite": "CVC_PP6A", "pumps": ["A","B","C","D","E","F","G","H"] },
    { "id": "pp6b", "name": "CVC PP 6B", "influxSite": "CVC_PP6B", "pumps": ["A","B","C","D"], "pumpLabels": {"A":"K","B":"L","C":"M","D":"N"} },
    { "id": "pp7a", "name": "CVC PP 7A", "influxSite": "CVC_PP7A", "pumps": ["A","B","C","D","E","F"] }
  ],

  "_powerNote": "Power monitoring reads the `power_meters` bucket (measurement `power_reading`, tagged by meter_id) on the same InfluxDB the SCADA pollers use. If a field name below doesn't match your actual meter schema, just edit it here — no code changes needed.",
  "power": {
    "bucket": "power_meters",
    "measurement": "power_reading",
    "nominalVoltageLN": 1440,
    "nominalVoltageLL": 2420,
    "thresholds": {
      "voltageImbalancePct": 2,
      "currentImbalancePct": 10,
      "pfMin": 0.85,
      "voltageDeviationPct": 5,
      "freqMin": 59.95,
      "freqMax": 60.05,
      "staleWarnSec": 120,
      "staleAlarmSec": 300
    },
    "sites": [
      { "id": "pp1a", "name": "PP 1A", "meterId": "Pumping_Plant_1A" },
      { "id": "pp2a", "name": "PP 2A", "meterId": "Pumping_Plant_2A" },
      { "id": "pp3a", "name": "PP 3A", "meterId": "Pumping_Plant_3A" },
      { "id": "pp4a", "name": "PP 4A", "meterId": "Pumping_Plant_4A" },
      { "id": "pp5a", "name": "PP 5A", "meterId": "Pumping_Plant_5A" },
      { "id": "pp6a", "name": "PP 6A", "meterId": "Pumping_Plant_6A" },
      { "id": "pp7a", "name": "PP 7A", "meterId": "Pumping_Plant_7A" }
    ],
    "groups": [
      { "key": "active",    "label": "Active Power",    "unit": "kW",   "chart": "line", "members": ["p1","p2","p3","psum_kw"],       "total": "psum_kw",   "defaultRange": "24h" },
      { "key": "voltageLN", "label": "Voltage (L-N)",   "unit": "V",    "chart": "line", "members": ["v1","v2","v3","vnavg_v"],       "total": "vnavg_v",   "defaultRange": "1h" },
      { "key": "voltageLL", "label": "Voltage (L-L)",   "unit": "V",    "chart": "line", "members": ["v12","v23","v31","viavg_v"],    "total": "viavg_v",   "defaultRange": "1h" },
      { "key": "current",   "label": "Current",         "unit": "A",    "chart": "line", "members": ["i1","i2","i3","iavg_a"],        "total": "iavg_a",    "defaultRange": "1h" },
      { "key": "pf",        "label": "Power Factor",    "unit": "",     "chart": "line", "members": ["pf1","pf2","pf3","pf"],         "total": "pf",        "defaultRange": "1h", "yMin": -1, "yMax": 1 },
      { "key": "frequency", "label": "Frequency",       "unit": "Hz",   "chart": "line", "members": ["freq_hz"],                      "total": "freq_hz",   "defaultRange": "1h" },
      { "key": "reactive",  "label": "Reactive Power",  "unit": "kVAR", "chart": "line", "members": ["q1","q2","q3","qsum_kvar"],     "total": "qsum_kvar", "defaultRange": "24h" },
      { "key": "apparent",  "label": "Apparent Power",  "unit": "kVA",  "chart": "line", "members": ["s1","s2","s3","ssum_kva"],      "total": "ssum_kva",  "defaultRange": "24h" },
      { "key": "demand",    "label": "Power Demand",    "unit": "",     "chart": "bar",  "members": ["dmd_p_kw","dmd_i1_a","dmd_i2_a","dmd_i3_a"], "defaultRange": "24h" }
    ],
    "fieldMeta": {
      "p1": { "label": "P1", "unit": "kW" }, "p2": { "label": "P2", "unit": "kW" }, "p3": { "label": "P3", "unit": "kW" },
      "psum_kw": { "label": "Total", "unit": "kW" },
      "v1": { "label": "V1", "unit": "V" }, "v2": { "label": "V2", "unit": "V" }, "v3": { "label": "V3", "unit": "V" },
      "vnavg_v": { "label": "Avg L-N", "unit": "V" },
      "v12": { "label": "V12", "unit": "V" }, "v23": { "label": "V23", "unit": "V" }, "v31": { "label": "V31", "unit": "V" },
      "viavg_v": { "label": "Avg L-L", "unit": "V" },
      "i1": { "label": "I1", "unit": "A" }, "i2": { "label": "I2", "unit": "A" }, "i3": { "label": "I3", "unit": "A" },
      "iavg_a": { "label": "Avg", "unit": "A" },
      "pf1": { "label": "PF1", "unit": "" }, "pf2": { "label": "PF2", "unit": "" }, "pf3": { "label": "PF3", "unit": "" },
      "pf": { "label": "PF", "unit": "" },
      "freq_hz": { "label": "Frequency", "unit": "Hz" },
      "q1": { "label": "Q1", "unit": "kVAR" }, "q2": { "label": "Q2", "unit": "kVAR" }, "q3": { "label": "Q3", "unit": "kVAR" },
      "qsum_kvar": { "label": "Total", "unit": "kVAR" },
      "s1": { "label": "S1", "unit": "kVA" }, "s2": { "label": "S2", "unit": "kVA" }, "s3": { "label": "S3", "unit": "kVA" },
      "ssum_kva": { "label": "Total", "unit": "kVA" },
      "ep_imp_kwh": { "label": "Import Energy", "unit": "kWh" },
      "ep_exp_kwh": { "label": "Export Energy", "unit": "kWh" },
      "dmd_p_kw":  { "label": "Demand kW",  "unit": "kW" },
      "dmd_q_kvar":{ "label": "Demand kVAR","unit": "kVAR" },
      "dmd_s_kva": { "label": "Demand kVA", "unit": "kVA" },
      "dmd_i1_a":  { "label": "Demand I1",  "unit": "A" },
      "dmd_i2_a":  { "label": "Demand I2",  "unit": "A" },
      "dmd_i3_a":  { "label": "Demand I3",  "unit": "A" }
    }
  }
}
